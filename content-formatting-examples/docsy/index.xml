&lt;link rel="preload" as="image" href="https://saurabhraghuvanshii.github.io/academy-example/content-formatting-examples/docsy/blocks-cover-link-down/background_hu_739988b8c547bd35.png" media="(max-width: 1200px)"&gt;
&lt;link rel="preload" as="image" href="https://saurabhraghuvanshii.github.io/academy-example/content-formatting-examples/docsy/blocks-cover-link-down/background_hu_280813ad007c96a9.png" media="(min-width: 1200px)"&gt;
